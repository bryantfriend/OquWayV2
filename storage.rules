rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function hasRole(role) {
      return request.auth != null && (
        request.auth.token.role == role ||
        (request.auth.token.roles is list && role in request.auth.token.roles) ||
        (request.auth.token.userRoles is list && role in request.auth.token.userRoles)
      );
    }

    function hasAnyRole(role, legacyRole) {
      return hasRole(role)
        || (request.auth != null && request.auth.token.role == legacyRole)
        || (request.auth != null && request.auth.token.roles is list && legacyRole in request.auth.token.roles)
        || (request.auth != null && request.auth.token.userRoles is list && legacyRole in request.auth.token.userRoles);
    }

    function user() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
        : null;
    }

    function profileIsActive() {
      return user() != null
        && (!(user().data.status is string)
          || user().data.status == "active"
          || user().data.status == "approved");
    }

    function profileHasAnyRole(role, legacyRole) {
      return profileIsActive() && (
        user().data.role == role ||
        user().data.role == legacyRole ||
        (user().data.roles is list && (role in user().data.roles || legacyRole in user().data.roles)) ||
        (legacyRole == "ROLE_TEACHER" && user().data.ROLE_TEACHER == true) ||
        (legacyRole == "ROLE_ASSISTANT" && user().data.ROLE_ASSISTANT == true) ||
        (legacyRole == "ROLE_STUDENT" && user().data.ROLE_STUDENT == true) ||
        (legacyRole == "ROLE_COURSE_CREATOR" && user().data.ROLE_COURSE_CREATOR == true) ||
        (legacyRole == "ROLE_SCHOOL_ADMIN" && user().data.ROLE_SCHOOL_ADMIN == true) ||
        (legacyRole == "ROLE_PLATFORM_ADMIN" && user().data.ROLE_PLATFORM_ADMIN == true) ||
        (legacyRole == "ROLE_SUPER_ADMIN" && user().data.ROLE_SUPER_ADMIN == true)
      );
    }

    function isSuperAdmin() { return hasAnyRole('superAdmin', 'ROLE_SUPER_ADMIN') || profileHasAnyRole('superAdmin', 'ROLE_SUPER_ADMIN'); }
    function isPlatformAdmin() { return hasAnyRole('platformAdmin', 'ROLE_PLATFORM_ADMIN') || profileHasAnyRole('platformAdmin', 'ROLE_PLATFORM_ADMIN'); }
    function isSchoolAdmin() { return hasAnyRole('schoolAdmin', 'ROLE_SCHOOL_ADMIN') || profileHasAnyRole('schoolAdmin', 'ROLE_SCHOOL_ADMIN'); }
    function isCourseCreator() { return hasAnyRole('courseCreator', 'ROLE_COURSE_CREATOR') || profileHasAnyRole('courseCreator', 'ROLE_COURSE_CREATOR'); }
    function isAssistant() { return hasAnyRole('assistant', 'ROLE_ASSISTANT') || profileHasAnyRole('assistant', 'ROLE_ASSISTANT'); }
    function isTeacher() { return hasAnyRole('teacher', 'ROLE_TEACHER') || profileHasAnyRole('teacher', 'ROLE_TEACHER'); }
    function hasStudentToken() {
      return request.auth != null && request.auth.token.studentId is string;
    }
    function isSameStudent(studentId) {
      return request.auth != null
        && studentId is string
        && (
          request.auth.uid == studentId ||
          (request.auth.token.studentId is string && request.auth.token.studentId == studentId)
        );
    }
    function isStudent() { return hasAnyRole('student', 'ROLE_STUDENT') || hasStudentToken() || profileHasAnyRole('student', 'ROLE_STUDENT'); }
    function isReviewer() { return isTeacher() || isCourseCreator() || isAssistant() || isSchoolAdmin() || isPlatformAdmin() || isSuperAdmin(); }

    function isAllowedExternalTaskFile() {
      return request.resource.size <= 10 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType == 'application/pdf' ||
          request.resource.contentType == 'application/msword' ||
          request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document' ||
          request.resource.contentType == 'application/vnd.ms-powerpoint' ||
          request.resource.contentType == 'application/vnd.openxmlformats-officedocument.presentationml.presentation' ||
          request.resource.contentType == 'application/vnd.ms-excel' ||
          request.resource.contentType == 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' ||
          request.resource.contentType == 'text/plain' ||
          request.resource.contentType == 'text/csv'
        );
    }

    function isAllowedStepMediaImage() {
      return request.resource.size <= 10 * 1024 * 1024
        && (
          request.resource.contentType == 'image/png' ||
          request.resource.contentType == 'image/jpeg' ||
          request.resource.contentType == 'image/jpg' ||
          request.resource.contentType == 'image/webp' ||
          request.resource.contentType == 'image/gif'
        );
    }

    function isAllowedStepMediaAudio() {
      return request.resource.size <= 10 * 1024 * 1024
        && (
          request.resource.contentType == 'audio/mpeg' ||
          request.resource.contentType == 'audio/mp3' ||
          request.resource.contentType == 'audio/wav' ||
          request.resource.contentType == 'audio/ogg' ||
          request.resource.contentType == 'audio/webm' ||
          request.resource.contentType == 'audio/mp4'
        );
    }

    function isAllowedStepMediaFile() {
      return isAllowedStepMediaImage() || isAllowedStepMediaAudio();
    }

    function catalogCourseDoc(courseId) {
      return firestore.exists(/databases/(default)/documents/catalogCourses/$(courseId))
        ? firestore.get(/databases/(default)/documents/catalogCourses/$(courseId))
        : null;
    }

    function legacyCourseDoc(courseId) {
      return firestore.exists(/databases/(default)/documents/courses/$(courseId))
        ? firestore.get(/databases/(default)/documents/courses/$(courseId))
        : null;
    }

    function courseAllowsEditor(courseDoc) {
      return courseDoc != null && (
        courseDoc.data.createdBy == request.auth.uid ||
        courseDoc.data.ownerId == request.auth.uid ||
        courseDoc.data.updatedBy == request.auth.uid ||
        (courseDoc.data.editorIds is list && request.auth.uid in courseDoc.data.editorIds) ||
        (courseDoc.data.courseCreatorIds is list && request.auth.uid in courseDoc.data.courseCreatorIds) ||
        (courseDoc.data.assistantIds is list && request.auth.uid in courseDoc.data.assistantIds)
      );
    }

    function canEditCourseMedia(courseId) {
      return isSchoolAdmin() ||
        isPlatformAdmin() ||
        isSuperAdmin() ||
        courseAllowsEditor(catalogCourseDoc(courseId)) ||
        courseAllowsEditor(legacyCourseDoc(courseId));
    }

    function canWriteStepMedia(courseId) {
      return request.auth != null
        && (isCourseCreator() || isAssistant() || isSchoolAdmin() || isPlatformAdmin() || isSuperAdmin())
        && canEditCourseMedia(courseId);
    }

    function courseIsPublished(courseDoc) {
      return courseDoc != null && (
        courseDoc.data.status == "published" ||
        courseDoc.data.isPublished == true ||
        courseDoc.data.published == true
      );
    }

    function canReadPublishedCourseMedia(courseId) {
      return isStudent() && (
        courseIsPublished(catalogCourseDoc(courseId)) ||
        courseIsPublished(legacyCourseDoc(courseId))
      );
    }

    function canReadStepMedia(courseId) {
      return request.auth != null && (
        canWriteStepMedia(courseId) ||
        canEditCourseMedia(courseId) ||
        isReviewer() ||
        isTeacher() ||
        canReadPublishedCourseMedia(courseId)
      );
    }

    function isAllowedLocationIcon() {
      return request.resource.size <= 2 * 1024 * 1024
        && (
          request.resource.contentType == 'image/png' ||
          request.resource.contentType == 'image/jpeg' ||
          request.resource.contentType == 'image/webp'
        );
    }

    function isAllowedCourseBuilderIcon() {
      return request.resource.size <= 5 * 1024 * 1024
        && (
          request.resource.contentType == 'image/png' ||
          request.resource.contentType == 'image/jpeg' ||
          request.resource.contentType == 'image/jpg' ||
          request.resource.contentType == 'image/webp'
        );
    }

    function canWriteLocationIcon() {
      return request.auth != null && (
        isSchoolAdmin() ||
        isPlatformAdmin() ||
        isSuperAdmin()
      );
    }

    function canWriteCourseBuilderIcon() {
      return request.auth != null && (
        isCourseCreator() ||
        isAssistant() ||
        isSchoolAdmin() ||
        isPlatformAdmin() ||
        isSuperAdmin()
      );
    }

    match /external-task-submissions/{courseId}/{moduleId}/{stepId}/{studentId}/{submissionId}/{fileName} {
      allow create: if request.auth != null
        && isSameStudent(studentId)
        && isStudent()
        && isAllowedExternalTaskFile();

      allow read: if request.auth != null && (
        isSameStudent(studentId) ||
        isReviewer()
      );

      allow update, delete: if false;
    }

    match /step-media/{courseId}/{moduleId}/{modeId}/{stepId}/{fileName} {
      allow read: if canReadStepMedia(courseId);

      allow create, update: if canWriteStepMedia(courseId)
        && isAllowedStepMediaFile();

      allow delete: if canWriteStepMedia(courseId);
    }

    match /location-icons/{locationId}/{fileName} {
      allow read: if true;

      allow create, update: if canWriteLocationIcon()
        && isAllowedLocationIcon();

      allow delete: if canWriteLocationIcon();
    }

    match /course-icons/{courseId}/{fileName} {
      allow read: if true;

      allow create, update: if canWriteCourseBuilderIcon()
        && isAllowedCourseBuilderIcon();

      allow delete: if canWriteCourseBuilderIcon();
    }

    match /module-icons/{courseId}/{moduleId}/{fileName} {
      allow read: if true;

      allow create, update: if canWriteCourseBuilderIcon()
        && isAllowedCourseBuilderIcon();

      allow delete: if canWriteCourseBuilderIcon();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
