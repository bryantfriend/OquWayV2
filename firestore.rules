rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    // 🔧 Helpers

    function hasRole(role) {
      return request.auth != null && (
        request.auth.token.role == role ||
        (request.auth.token.roles is list && role in request.auth.token.roles) ||
        (request.auth.token.userRoles is list && role in request.auth.token.userRoles)
      );
    }

    function hasAnyRole(role, legacyRole) {
      return hasRole(role)
        || (request.auth != null && request.auth.token.role == legacyRole)
        || (request.auth != null && request.auth.token.roles is list && legacyRole in request.auth.token.roles)
        || (request.auth != null && request.auth.token.userRoles is list && legacyRole in request.auth.token.userRoles);
    }

    function profileIsActive() {
      return user() != null && user().data.get("status", "") in ["", "active", "approved"];
    }

    function profileHasAnyRole(role, legacyRole) {
      return profileIsActive() && (
        user().data.get("role", "") in [role, legacyRole] ||
        (user().data.get("roles", []) is list && (role in user().data.get("roles", []) || legacyRole in user().data.get("roles", []))) ||
        (legacyRole == "ROLE_TEACHER" && user().data.get("ROLE_TEACHER", false) == true) ||
        (legacyRole == "ROLE_ASSISTANT" && user().data.get("ROLE_ASSISTANT", false) == true) ||
        (legacyRole == "ROLE_STUDENT" && user().data.get("ROLE_STUDENT", false) == true) ||
        (legacyRole == "ROLE_COURSE_CREATOR" && user().data.get("ROLE_COURSE_CREATOR", false) == true) ||
        (legacyRole == "ROLE_ACCOUNTANT" && user().data.get("ROLE_ACCOUNTANT", false) == true) ||
        (legacyRole == "ROLE_SCHOOL_ADMIN" && user().data.get("ROLE_SCHOOL_ADMIN", false) == true) ||
        (legacyRole == "ROLE_PLATFORM_ADMIN" && user().data.get("ROLE_PLATFORM_ADMIN", false) == true) ||
        (legacyRole == "ROLE_SUPER_ADMIN" && user().data.get("ROLE_SUPER_ADMIN", false) == true)
      );
    }

    function isSuperAdmin() { return hasAnyRole('superAdmin', 'ROLE_SUPER_ADMIN'); }
    function isPlatformAdmin() { return hasAnyRole('platformAdmin', 'ROLE_PLATFORM_ADMIN'); }
    function isSchoolAdmin() { return hasAnyRole('schoolAdmin', 'ROLE_SCHOOL_ADMIN'); }
    function isCourseCreator() { return hasAnyRole('courseCreator', 'ROLE_COURSE_CREATOR'); }
    function isAssistant() { return hasAnyRole('assistant', 'ROLE_ASSISTANT') || profileHasAnyRole('assistant', 'ROLE_ASSISTANT'); }
    function isCourseEditor() { return isCourseCreator() || isAssistant(); }
    function isAccountant() { return hasAnyRole('accountant', 'ROLE_ACCOUNTANT'); }
    function isTeacher() { return hasAnyRole('teacher', 'ROLE_TEACHER') || profileHasAnyRole('teacher', 'ROLE_TEACHER'); }
    function hasStudentToken() { return request.auth != null && request.auth.token.studentId is string; }
    function isSameStudent(studentId) {
      return request.auth != null
        && studentId is string
        && (
          request.auth.uid == studentId ||
          (request.auth.token.studentId is string && request.auth.token.studentId == studentId)
        );
    }
    function hasStudentProfile() {
      return profileIsActive() && (
        isSameStudent(user().data.get("studentId", "")) ||
        user().data.get("role", "") in ["student", "Student", "ROLE_STUDENT"] ||
        (user().data.get("roles", []) is list && ("student" in user().data.get("roles", []) || "Student" in user().data.get("roles", []) || "ROLE_STUDENT" in user().data.get("roles", []))) ||
        user().data.get("ROLE_STUDENT", false) == true
      );
    }
    function isStudent() { return hasAnyRole('student', 'ROLE_STUDENT') || hasStudentToken() || profileHasAnyRole('student', 'ROLE_STUDENT') || hasStudentProfile(); }


    function user() {
      return request.auth != null
        && exists(/databases/$(db)/documents/users/$(request.auth.uid))
        ? get(/databases/$(db)/documents/users/$(request.auth.uid))
        : null;
    }

    function linkedUser() {
      return user() != null
        && user().data.get("profileUserId", "") is string
        && user().data.get("profileUserId", "") != ""
        && user().data.get("profileUserId", "") != request.auth.uid
        && exists(/databases/$(db)/documents/users/$(user().data.get("profileUserId", "")))
        ? get(/databases/$(db)/documents/users/$(user().data.get("profileUserId", "")))
        : null;
    }

    function sameSchool() {
      return user() != null && (
        // for updates / reads
        (resource != null && resource.data.schoolId == user().data.schoolId) ||
        // for creates
        (request.resource != null && request.resource.data.schoolId == user().data.schoolId)
      );
    }

    // --- ADMIN ROLES HELPER (FOR ACCOUNTING) ---
    function isAccountingAdmin() {
      return request.auth != null && (isSuperAdmin() || isPlatformAdmin() || isSchoolAdmin() || isAccountant());
    }

    function isExternalTaskAdminReviewer() {
      return request.auth != null && (isCourseEditor() || isSchoolAdmin() || isPlatformAdmin() || isSuperAdmin());
    }

    function teacherHasClass(classId) {
      return user() != null && classId is string && classId != "" && (
        classId == user().data.get("classId", "") ||
        classId in user().data.get("classIds", []) ||
        classId in user().data.get("assignedClassIds", []) ||
        (linkedUser() != null && (
          classId == linkedUser().data.get("classId", "") ||
          classId in linkedUser().data.get("classIds", []) ||
          classId in linkedUser().data.get("assignedClassIds", [])
        ))
      );
    }

    function listHasTeacherClass(classIds) {
      return classIds is list && classIds.size() > 0 && user() != null && (
        user().data.get("classId", "") in classIds ||
        user().data.get("classIds", []).hasAny(classIds) ||
        user().data.get("assignedClassIds", []).hasAny(classIds) ||
        (linkedUser() != null && (
          linkedUser().data.get("classId", "") in classIds ||
          linkedUser().data.get("classIds", []).hasAny(classIds) ||
          linkedUser().data.get("assignedClassIds", []).hasAny(classIds)
        ))
      );
    }

    function teacherHasLocation(locationId) {
      return user() != null && locationId is string && locationId != "" && (
        locationId in [user().data.get("locationId", ""), user().data.get("primaryLocationId", ""), user().data.get("schoolId", "")] ||
        locationId in user().data.get("locationIds", []) ||
        locationId in user().data.get("schoolIds", []) ||
        (linkedUser() != null && (
          locationId in [linkedUser().data.get("locationId", ""), linkedUser().data.get("primaryLocationId", ""), linkedUser().data.get("schoolId", "")] ||
          locationId in linkedUser().data.get("locationIds", []) ||
          locationId in linkedUser().data.get("schoolIds", [])
        ))
      );
    }

    function teacherHasProfileId(profileId) {
      return user() != null && profileId is string && profileId != "" && (
        profileId in [request.auth.uid, user().data.get("profileUserId", ""), user().data.get("userId", ""), user().data.get("teacherId", ""), user().data.get("authUid", "")] ||
        (linkedUser() != null && profileId in [linkedUser().data.get("profileUserId", ""), linkedUser().data.get("userId", ""), linkedUser().data.get("teacherId", ""), linkedUser().data.get("authUid", "")])
      );
    }

    function listHasTeacherProfileId(profileIds) {
      return profileIds is list && profileIds.size() > 0 && user() != null && (
        request.auth.uid in profileIds ||
        user().data.get("profileUserId", "") in profileIds ||
        user().data.get("userId", "") in profileIds ||
        user().data.get("teacherId", "") in profileIds ||
        user().data.get("authUid", "") in profileIds ||
        (linkedUser() != null && (
          linkedUser().data.get("profileUserId", "") in profileIds ||
          linkedUser().data.get("userId", "") in profileIds ||
          linkedUser().data.get("teacherId", "") in profileIds ||
          linkedUser().data.get("authUid", "") in profileIds
        ))
      );
    }

    function listHasTeacherOwnershipId(ownershipIds) {
      return listHasTeacherProfileId(ownershipIds);
    }

    function isTeacherAssignedToClass(classData, classId) {
      return (isTeacher() || isAssistant()) && user() != null && (
        teacherHasClass(classId) ||
        teacherHasProfileId(classData.get("primaryTeacherId", "")) ||
        teacherHasProfileId(classData.get("teacherId", "")) ||
        teacherHasProfileId(classData.get("responsibleTeacherId", "")) ||
        teacherHasProfileId(classData.get("primaryTeacherAuthUid", "")) ||
        teacherHasProfileId(classData.get("teacherAuthUid", "")) ||
        listHasTeacherProfileId(classData.get("assistantIds", [])) ||
        listHasTeacherProfileId(classData.get("teacherOwnershipIds", [])) ||
        listHasTeacherProfileId(classData.get("teacherIds", [])) ||
        listHasTeacherProfileId(classData.get("assignedTeacherIds", []))
      );
    }

    function isTeacherAssignedToClassId(classId) {
      return (isTeacher() || isAssistant())
        && user() != null
        && classId is string
        && classId != ""
        && exists(/databases/$(db)/documents/classes/$(classId))
        && isTeacherAssignedToClass(get(/databases/$(db)/documents/classes/$(classId)).data, classId);
    }

    function isTeacherAssignedToCourseAssignment(assignmentData) {
      return (isTeacher() || isAssistant()) && user() != null && (
        listHasTeacherOwnershipId(assignmentData.get("teacherOwnershipIds", [])) ||
        teacherHasProfileId(assignmentData.get("responsibleTeacherId", "")) ||
        listHasTeacherProfileId(assignmentData.get("assistantIds", [])) ||
        (assignmentData.get("targetType", "") == "class" && isTeacherAssignedToClassId(assignmentData.get("targetId", ""))) ||
        isTeacherAssignedToClassId(assignmentData.get("classId", ""))
      );
    }

    function isTeacherAssignedToCourseAssignmentId(assignmentId) {
      return (isTeacher() || isAssistant())
        && user() != null
        && assignmentId is string
        && assignmentId != ""
        && exists(/databases/$(db)/documents/courseAssignments/$(assignmentId))
        && isTeacherAssignedToCourseAssignment(get(/databases/$(db)/documents/courseAssignments/$(assignmentId)).data);
    }

    function isCourseAssignmentOwnershipAdmin() {
      return isSuperAdmin() || isPlatformAdmin() || isSchoolAdmin();
    }

    function courseAssignmentOwnershipKeys() {
      return ["responsibleTeacherId", "assistantIds", "teacherOwnershipIds", "responsibleTeacherName", "assistantNames"];
    }

    function courseAssignmentCreateOwnershipAllowed() {
      return isCourseAssignmentOwnershipAdmin() || (
        request.resource.data.get("responsibleTeacherId", "") == "" &&
        request.resource.data.get("assistantIds", []).size() == 0 &&
        request.resource.data.get("teacherOwnershipIds", []).size() == 0 &&
        request.resource.data.get("responsibleTeacherName", "") == "" &&
        request.resource.data.get("assistantNames", []).size() == 0
      );
    }

    function courseAssignmentUpdateOwnershipAllowed() {
      return isCourseAssignmentOwnershipAdmin()
        || !request.resource.data.diff(resource.data).affectedKeys().hasAny(courseAssignmentOwnershipKeys());
    }

    function isStudentInTeacherClass() {
      return isTeacher()
        && user() != null
        && studentDataHasTeacherClass(resource.data);
    }

    function isStudentProfileResource() {
      return resource.data.get("role", "") in ["student", "Student", "ROLE_STUDENT"] ||
        (resource.data.get("roles", []) is list && ("student" in resource.data.get("roles", []) || "Student" in resource.data.get("roles", []) || "ROLE_STUDENT" in resource.data.get("roles", []))) ||
        resource.data.get("ROLE_STUDENT", false) == true ||
        resource.data.get("classId", null) is string ||
        resource.data.get("primaryClassId", null) is string ||
        resource.data.get("classIds", []) is list ||
        resource.data.get("assignedClassIds", []) is list;
    }

    function isStudentInTeacherListedClass() {
      return isTeacher()
        && user() != null
        && isStudentProfileResource()
        && studentDataHasTeacherClass(resource.data);
    }

    function isUserInTeacherClass(uid) {
      return isTeacher()
        && user() != null
        && uid is string
        && uid != ""
        && exists(/databases/$(db)/documents/users/$(uid))
        && studentDataHasTeacherClass(get(/databases/$(db)/documents/users/$(uid)).data);
    }

    function studentDataHasTeacherClass(studentData) {
      return (
        isTeacherAssignedToClassId(studentData.get("classId", "")) ||
        isTeacherAssignedToClassId(studentData.get("primaryClassId", "")) ||
        teacherHasClass(studentData.get("classId", "")) ||
        teacherHasClass(studentData.get("primaryClassId", "")) ||
        teacherHasClass(studentData.get("className", "")) ||
        listHasTeacherClass(studentData.get("classIds", [])) ||
        listHasTeacherClass(studentData.get("assignedClassIds", []))
      );
    }

    function isTeacherInExternalTaskScope() {
      return request.auth != null && (isTeacher() || isAssistant()) && user() != null && (
        listHasTeacherOwnershipId(resource.data.get("teacherOwnershipIds", [])) ||
        isTeacherAssignedToCourseAssignmentId(resource.data.get("assignmentId", "")) ||
        isTeacherAssignedToCourseAssignmentId(resource.data.get("courseAssignmentId", "")) ||
        isTeacherAssignedToClassId(resource.data.get("classId", "")) ||
        teacherHasClass(resource.data.get("classId", "")) ||
        teacherHasLocation(resource.data.get("locationId", ""))
      );
    }

    // 👤 USERS
    match /users/{uid} {
      allow get: if
        // 1. Allow the user to read their own profile (essential for claims)
        isSameStudent(uid) ||
        (resource.data.authUid is string && resource.data.authUid == request.auth.uid) ||
        // 2. Allow any Accounting Admin to read ANY user document
        isAccountingAdmin() ||
        // 3. Allow Teachers to read students in their classes (existing logic)
        isStudentInTeacherClass();

      allow list: if
        (resource.data.authUid is string && resource.data.authUid == request.auth.uid) ||
        isAccountingAdmin() ||
        isStudentInTeacherListedClass();

      // Allow admins to create new users and allow both admins and user to update profile
      allow create: if isAccountingAdmin() || isSameStudent(uid);
      allow update: if isAccountingAdmin() || isSameStudent(uid) || (resource.data.authUid is string && resource.data.authUid == request.auth.uid);

      allow delete: if isSuperAdmin() || isPlatformAdmin();

      match /modules_completed/{moduleId} {
        allow read: if isSameStudent(uid)
                        || isSuperAdmin()
                        || isPlatformAdmin()
                        || isSchoolAdmin();
        allow write: if isSameStudent(uid);
      }
    }

  // 📍 LOCATIONS
    match /locations/{locId} {
      allow read: if true;
      allow create, delete: if isSuperAdmin() || isPlatformAdmin();
      allow update: if isSuperAdmin()
        || isPlatformAdmin()
        || isSchoolAdmin()
        || isCourseEditor();

      // 🧾 EXPENSE CATEGORIES (subcollection)
      match /expense_categories/{categoryId} {
        allow read, list, create, update, delete: if isAccountingAdmin();
      }

      // 📚 CLASSES (subcollection)
      // --- ADD THIS BLOCK ---
      match /classes/{classId} {
          // Allow accountants/admins to read and write classes
          allow read, list: if isAccountingAdmin()
            || isStudent()
            || (isTeacher() && (teacherHasClass(classId) || teacherHasLocation(locId)))
            || isTeacherAssignedToClass(resource.data, classId);
          allow create, update, delete: if isAccountingAdmin();
      }
    }


    // 📚 CLASSES
    match /classes/{classId} {
      allow read: if true;
      allow write: if isSuperAdmin()
                  || isPlatformAdmin()
                  || (isSchoolAdmin() && sameSchool());
    }

    // 🧠 CLASS TEMPLATES
    match /classTemplates/{templateId} {
      allow read: if isSuperAdmin() || isPlatformAdmin() || isSchoolAdmin();
      allow write: if isSuperAdmin() || isPlatformAdmin() || (isSchoolAdmin() && sameSchool());
    }

    // 📘 COURSES
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();

      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();

        match /sessions/{sessionId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
        }

        match /learningContent/{contentId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
        }

        match /learningModes/{modeId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();

          match /steps/{stepId} {
            allow read: if true;
            allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
          }
        }
      }
    }

    // 🎯 COURSE ASSIGNMENTS
    match /courseAssignments/{assignmentId} {
      allow get, list: if request.auth != null;

      allow create: if request.auth != null && (
        isSuperAdmin() ||
        isPlatformAdmin() ||
        isSchoolAdmin() ||
        isCourseEditor()
      ) && courseAssignmentCreateOwnershipAllowed();

      allow update: if request.auth != null && (
        isSuperAdmin() ||
        isPlatformAdmin() ||
        isSchoolAdmin() ||
        isCourseEditor()
      ) && courseAssignmentUpdateOwnershipAllowed();

      allow delete: if isSuperAdmin() || isPlatformAdmin();
    }

    // 🧾 EXTERNAL TASK SUBMISSIONS
    match /externalTaskSubmissions/{submissionId} {
      allow create: if request.auth != null
        && isStudent()
        && isSameStudent(request.resource.data.studentId)
        && request.resource.data.reviewStatus == "pending"
        && request.resource.data.status == "submitted";

      allow read, list: if request.auth != null && (
        isSameStudent(resource.data.studentId) ||
        isExternalTaskAdminReviewer() ||
        isTeacherInExternalTaskScope()
      );

      allow update: if request.auth != null && (
        (
          isStudent()
          && isSameStudent(resource.data.studentId)
          && (resource.data.reviewStatus == "pending" || resource.data.reviewStatus == "needsWork")
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            "reviewStatus",
            "reviewedBy",
            "reviewedAt",
            "teacherFeedback"
          ])
        ) ||
        (
          (isExternalTaskAdminReviewer() || isTeacherInExternalTaskScope())
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "reviewStatus",
            "reviewedBy",
            "reviewedAt",
            "teacherFeedback",
            "status",
            "updatedAt"
          ])
        )
      );

      allow delete: if isSuperAdmin() || isPlatformAdmin();
    }

    // 📚 CATALOG COURSES (New V2 Core Database)
    match /catalogCourses/{courseId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();

      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();

        match /sessions/{sessionId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
        }

        match /learningContent/{contentId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
        }

        match /learningModes/{modeId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();

          match /steps/{stepId} {
            allow read: if true;
            allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
          }
        }
      }
    }

    // 🎓 STUDENT PROGRESS
    match /studentProgress/{studentId} {
      allow read: if request.auth != null && (
        isSameStudent(studentId) ||
        isUserInTeacherClass(studentId) ||
        isSuperAdmin() ||
        isPlatformAdmin() ||
        isSchoolAdmin()
      );
      allow create, update: if isSameStudent(studentId);
      allow delete: if isSuperAdmin() || isPlatformAdmin();

      match /courses/{courseId} {
        allow read: if request.auth != null && (
          isSameStudent(studentId) ||
          isUserInTeacherClass(studentId) ||
          isSuperAdmin() ||
          isPlatformAdmin() ||
          isSchoolAdmin()
        );
        allow create, update: if isSameStudent(studentId);
        allow delete: if isSuperAdmin() || isPlatformAdmin();

        match /sessions/{sessionId} {
          allow read: if request.auth != null && (
            isSameStudent(studentId) ||
            isUserInTeacherClass(studentId) ||
            isSuperAdmin() ||
            isPlatformAdmin() ||
            isSchoolAdmin()
          );
          allow create, update: if isSameStudent(studentId);
          allow delete: if isSuperAdmin() || isPlatformAdmin();
        }
      }
    }

    // 👥 CUSTOMERS
    match /customers/{customerId} {
      allow read, list: if isAccountingAdmin();
      allow create: if isAccountingAdmin();
      allow update: if isAccountingAdmin();
      allow delete: if isSuperAdmin() || isPlatformAdmin();
    }

    // 🧩 STEP DEFINITIONS (RUNTIME STEPS)
    match /courses/{courseId}/modules/{moduleId}/steps/{stepId} {
      allow read: if true; // students must read steps to run engines
      allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
    }

    // 🧩 STEP DEFINITIONS FOR CATALOG COURSES (RUNTIME STEPS)
    match /catalogCourses/{courseId}/modules/{moduleId}/steps/{stepId} {
      allow read: if true; // students must read steps to run engines
      allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
    }


    // 📊 STEP RESULTS (Used by Teacher Dashboard)
    match /stepResults/{resultId} {
      allow read: if request.auth != null && (
          isTeacher() || isSuperAdmin() || isPlatformAdmin() || isSchoolAdmin()
      );

      // Optional: allow students to write their own results
      allow create: if isSameStudent(request.resource.data.studentId);

      // Optional: only admins can delete
      allow delete: if isSuperAdmin() || isPlatformAdmin();

      // Prevent anyone from updating results (they should be immutable)
      allow update: if false;
    }


    // 🔐 PERMISSIONS
    match /permissions/{permId} {
      allow read, write: if isSuperAdmin() || isPlatformAdmin();
    }

    // ⚙️ SETTINGS
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAccountingAdmin();
    }
    match /fees/{docId} {
      allow read: if request.auth != null;
      allow write: if isAccountingAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isPlatformAdmin();
    }

    // ---
    // --- ACCOUNTING COLLECTIONS ---
    // ---

    // 💰 PAYMENTS
    match /payments/{payId} {
      // Use the accounting helper
      allow read, write: if isAccountingAdmin();
    }

    // 💸 EXPENSES
    match /expenses/{expenseId} {
      // Use the accounting helper
      allow read, write: if isAccountingAdmin();
    }

    // 📄 SUBSCRIPTIONS
    match /subscriptions/{subId} {
      allow read, write: if isSuperAdmin() || isAccountant();
    }

    // 🏷 STEP METADATA (Tags)
    match /step_metadata/{stepId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
    }

    // 🛒 STORE PURCHASES
    match /store_purchases/{purchaseId} {
      allow read: if isSuperAdmin() || isAccountant() || isSchoolAdmin();
      allow write: if isSuperAdmin() || isAccountant();
    }

    // 📊 AUDIT LOGS
    match /audit_logs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // 🧾 RECURRING BILLS
    match /recurring_bills/{billId} {
      // Use the accounting helper
      allow read, list, create, update, delete: if isAccountingAdmin();

      match /history/{entryId} {
        allow read, write: if isAccountingAdmin();
      }
    }

    // 💵 SALARIES
    match /salaries/{salaryId} {
      // Use the same accounting helper
      allow read, list, create, update, delete: if isAccountingAdmin();
    }

    // 📋 LESSON LOG
    match /lesson_log/{lessonId} {
      // Allow accountants/admins to read and write lesson logs
      allow read, write: if isAccountingAdmin();
    }

    // 🧩 STEP COLLECTION GROUP (for editors, registry, runtime)
    match /{path=**}/steps/{stepId} {
      allow read: if isStudent() || isTeacher() || isAssistant() || isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
      allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
    }

    match /stepTypes/{stepTypeId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
    }

    // 🧩 SYSTEM STEP TYPES (Cloud Code)
    match /system_step_types/{stepId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
    }
  }
}
