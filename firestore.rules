rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    // 🔧 Helpers

    function hasRole(role) {
      return request.auth != null && (
        request.auth.token.role == role ||
        (request.auth.token.roles is list && role in request.auth.token.roles) ||
        (request.auth.token.userRoles is list && role in request.auth.token.userRoles)
      );
    }

    function hasAnyRole(role, legacyRole) {
      return hasRole(role)
        || (request.auth != null && request.auth.token.role == legacyRole)
        || (request.auth != null && request.auth.token.roles is list && legacyRole in request.auth.token.roles)
        || (request.auth != null && request.auth.token.userRoles is list && legacyRole in request.auth.token.userRoles);
    }

    function profileIsActive() {
      return user() != null
        && (!(user().data.status is string)
          || user().data.status == "active"
          || user().data.status == "approved");
    }

    function profileHasAnyRole(role, legacyRole) {
      return profileIsActive() && (
        user().data.role == role ||
        user().data.role == legacyRole ||
        (user().data.roles is list && (role in user().data.roles || legacyRole in user().data.roles)) ||
        (legacyRole == "ROLE_TEACHER" && user().data.ROLE_TEACHER == true) ||
        (legacyRole == "ROLE_ASSISTANT" && user().data.ROLE_ASSISTANT == true) ||
        (legacyRole == "ROLE_STUDENT" && user().data.ROLE_STUDENT == true) ||
        (legacyRole == "ROLE_COURSE_CREATOR" && user().data.ROLE_COURSE_CREATOR == true) ||
        (legacyRole == "ROLE_ACCOUNTANT" && user().data.ROLE_ACCOUNTANT == true) ||
        (legacyRole == "ROLE_SCHOOL_ADMIN" && user().data.ROLE_SCHOOL_ADMIN == true) ||
        (legacyRole == "ROLE_PLATFORM_ADMIN" && user().data.ROLE_PLATFORM_ADMIN == true) ||
        (legacyRole == "ROLE_SUPER_ADMIN" && user().data.ROLE_SUPER_ADMIN == true)
      );
    }

    function isSuperAdmin() { return hasAnyRole('superAdmin', 'ROLE_SUPER_ADMIN'); }
    function isPlatformAdmin() { return hasAnyRole('platformAdmin', 'ROLE_PLATFORM_ADMIN'); }
    function isSchoolAdmin() { return hasAnyRole('schoolAdmin', 'ROLE_SCHOOL_ADMIN'); }
    function isCourseCreator() { return hasAnyRole('courseCreator', 'ROLE_COURSE_CREATOR'); }
    function isAssistant() { return hasAnyRole('assistant', 'ROLE_ASSISTANT') || profileHasAnyRole('assistant', 'ROLE_ASSISTANT'); }
    function isCourseEditor() { return isCourseCreator() || isAssistant(); }
    function isAccountant() { return hasAnyRole('accountant', 'ROLE_ACCOUNTANT'); }
    function isTeacher() { return hasAnyRole('teacher', 'ROLE_TEACHER') || profileHasAnyRole('teacher', 'ROLE_TEACHER'); }
    function hasStudentToken() {
      return request.auth != null && request.auth.token.studentId is string;
    }
    function isSameStudent(studentId) {
      return request.auth != null
        && studentId is string
        && (
          request.auth.uid == studentId ||
          (request.auth.token.studentId is string && request.auth.token.studentId == studentId)
        );
    }
    function hasStudentProfile() {
      return profileIsActive() && (
        isSameStudent(user().data.studentId) ||
        user().data.role == "student" ||
        user().data.role == "Student" ||
        user().data.role == "ROLE_STUDENT" ||
        (user().data.roles is list && ("student" in user().data.roles || "Student" in user().data.roles || "ROLE_STUDENT" in user().data.roles)) ||
        user().data.ROLE_STUDENT == true
      );
    }
    function isStudent() { return hasAnyRole('student', 'ROLE_STUDENT') || hasStudentToken() || profileHasAnyRole('student', 'ROLE_STUDENT') || hasStudentProfile(); }


    function user() {
      return request.auth != null
        && exists(/databases/$(db)/documents/users/$(request.auth.uid))
        ? get(/databases/$(db)/documents/users/$(request.auth.uid))
        : null;
    }

    function linkedUser() {
      return request.auth != null
        && user() != null
        && user().data.profileUserId is string
        && user().data.profileUserId != request.auth.uid
        && exists(/databases/$(db)/documents/users/$(user().data.profileUserId))
        ? get(/databases/$(db)/documents/users/$(user().data.profileUserId))
        : null;
    }

    function sameSchool() {
      return user() != null && (
        // for updates / reads
        (resource != null && resource.data.schoolId == user().data.schoolId) ||
        // for creates
        (request.resource != null && request.resource.data.schoolId == user().data.schoolId)
      );
    }

    function isRelevantCourseAssignment() {
      return request.auth != null
        && resource.data.status == "active"
        && (
          (resource.data.targetType == "student"
            && (resource.data.targetId == request.auth.uid
              || (request.auth.token.studentId is string && resource.data.targetId == request.auth.token.studentId)))
          || (user() != null
            && resource.data.targetType == "class"
            && resource.data.targetId == user().data.classId)
          || (user() != null
            && resource.data.targetType == "class"
            && (user().data.classIds is list)
            && resource.data.targetId in user().data.classIds)
          || (resource.data.targetType == "class"
            && request.auth.token.classId is string
            && resource.data.targetId == request.auth.token.classId)
          || (resource.data.targetType == "class"
            && request.auth.token.className is string
            && resource.data.targetId == request.auth.token.className)
          || (resource.data.targetType == "class"
            && resource.data.classId is string
            && request.auth.token.classId is string
            && resource.data.classId == request.auth.token.classId)
          || (resource.data.targetType == "class"
            && resource.data.classId is string
            && request.auth.token.className is string
            && resource.data.classId == request.auth.token.className)
          || (user() != null
            && resource.data.targetType == "location"
            && resource.data.targetId == user().data.locationId)
          || (user() != null
            && resource.data.targetType == "location"
            && resource.data.targetId == user().data.locId)
          || (user() != null
            && resource.data.targetType == "location"
            && (user().data.locationIds is list)
            && resource.data.targetId in user().data.locationIds)
        );
    }


    // --- ADMIN ROLES HELPER (FOR ACCOUNTING) ---
    function isAccountingAdmin() {
      return request.auth != null && (
        isSuperAdmin() ||
        isPlatformAdmin() ||
        isSchoolAdmin() ||
        isAccountant()
      );
    }

    function isExternalTaskAdminReviewer() {
      return request.auth != null && (
        isCourseEditor() ||
        isSchoolAdmin() ||
        isPlatformAdmin() ||
        isSuperAdmin()
      );
    }

    function teacherClassIds() {
      return user() != null
        ? ((user().data.classIds is list ? user().data.classIds : [])
          + (user().data.assignedClassIds is list ? user().data.assignedClassIds : [])
          + (user().data.classId is string ? [user().data.classId] : [])
          + (linkedUser() != null && linkedUser().data.classIds is list ? linkedUser().data.classIds : [])
          + (linkedUser() != null && linkedUser().data.assignedClassIds is list ? linkedUser().data.assignedClassIds : [])
          + (linkedUser() != null && linkedUser().data.classId is string ? [linkedUser().data.classId] : []))
        : [];
    }

    function teacherLocationIds() {
      return user() != null
        ? ((user().data.locationIds is list ? user().data.locationIds : [])
          + (user().data.schoolIds is list ? user().data.schoolIds : [])
          + (user().data.locationId is string ? [user().data.locationId] : [])
          + (user().data.primaryLocationId is string ? [user().data.primaryLocationId] : [])
          + (user().data.schoolId is string ? [user().data.schoolId] : [])
          + (linkedUser() != null && linkedUser().data.locationIds is list ? linkedUser().data.locationIds : [])
          + (linkedUser() != null && linkedUser().data.schoolIds is list ? linkedUser().data.schoolIds : [])
          + (linkedUser() != null && linkedUser().data.locationId is string ? [linkedUser().data.locationId] : [])
          + (linkedUser() != null && linkedUser().data.primaryLocationId is string ? [linkedUser().data.primaryLocationId] : [])
          + (linkedUser() != null && linkedUser().data.schoolId is string ? [linkedUser().data.schoolId] : []))
        : [];
    }

    function teacherProfileIds() {
      return user() != null
        ? ([request.auth.uid]
          + (user().data.profileUserId is string ? [user().data.profileUserId] : [])
          + (user().data.userId is string ? [user().data.userId] : [])
          + (user().data.teacherId is string ? [user().data.teacherId] : [])
          + (user().data.authUid is string ? [user().data.authUid] : [])
          + (linkedUser() != null && linkedUser().data.profileUserId is string ? [linkedUser().data.profileUserId] : [])
          + (linkedUser() != null && linkedUser().data.userId is string ? [linkedUser().data.userId] : [])
          + (linkedUser() != null && linkedUser().data.teacherId is string ? [linkedUser().data.teacherId] : [])
          + (linkedUser() != null && linkedUser().data.authUid is string ? [linkedUser().data.authUid] : []))
        : [];
    }

    function teacherOwnershipIds() {
      return user() != null
        ? ([request.auth.uid]
          + (user().data.profileUserId is string ? [user().data.profileUserId] : [])
          + (user().data.userId is string ? [user().data.userId] : [])
          + (user().data.teacherId is string ? [user().data.teacherId] : [])
          + (user().data.authUid is string ? [user().data.authUid] : [])
          + (linkedUser() != null && linkedUser().data.profileUserId is string ? [linkedUser().data.profileUserId] : [])
          + (linkedUser() != null && linkedUser().data.userId is string ? [linkedUser().data.userId] : [])
          + (linkedUser() != null && linkedUser().data.teacherId is string ? [linkedUser().data.teacherId] : [])
          + (linkedUser() != null && linkedUser().data.authUid is string ? [linkedUser().data.authUid] : []))
        : (request.auth != null ? [request.auth.uid] : []);
    }

    function isTeacherAssignedToClass(classData, classId) {
      return (isTeacher() || isAssistant())
        && user() != null
        && (
          classId in teacherClassIds() ||
          (classData.primaryTeacherId is string && classData.primaryTeacherId in teacherProfileIds()) ||
          (classData.teacherId is string && classData.teacherId in teacherProfileIds()) ||
          (classData.responsibleTeacherId is string && classData.responsibleTeacherId in teacherProfileIds()) ||
          (classData.primaryTeacherAuthUid is string && classData.primaryTeacherAuthUid in teacherProfileIds()) ||
          (classData.teacherAuthUid is string && classData.teacherAuthUid in teacherProfileIds()) ||
          (classData.assistantIds is list && classData.assistantIds.hasAny(teacherProfileIds())) ||
          (classData.teacherOwnershipIds is list && classData.teacherOwnershipIds.hasAny(teacherProfileIds())) ||
          (classData.teacherIds is list && classData.teacherIds.hasAny(teacherProfileIds())) ||
          (classData.assignedTeacherIds is list && classData.assignedTeacherIds.hasAny(teacherProfileIds()))
        );
    }

    function isTeacherAssignedToClassId(classId) {
      return (isTeacher() || isAssistant())
        && user() != null
        && classId is string
        && exists(/databases/$(db)/documents/classes/$(classId))
        && isTeacherAssignedToClass(get(/databases/$(db)/documents/classes/$(classId)).data, classId);
    }

    function isTeacherAssignedToCourseAssignment(assignmentData) {
      return (isTeacher() || isAssistant())
        && user() != null
        && (
          (assignmentData.teacherOwnershipIds is list && assignmentData.teacherOwnershipIds.hasAny(teacherOwnershipIds())) ||
          (assignmentData.responsibleTeacherId is string && assignmentData.responsibleTeacherId in teacherProfileIds()) ||
          (assignmentData.assistantIds is list && assignmentData.assistantIds.hasAny(teacherProfileIds())) ||
          (assignmentData.targetType == "class" && assignmentData.targetId is string && isTeacherAssignedToClassId(assignmentData.targetId)) ||
          (assignmentData.classId is string && isTeacherAssignedToClassId(assignmentData.classId))
        );
    }

    function isTeacherOwnedAssignment() {
      return (isTeacher() || isAssistant())
        && user() != null
        && (
          (resource.data.teacherOwnershipIds is list && resource.data.teacherOwnershipIds.hasAny(teacherOwnershipIds())) ||
          (resource.data.responsibleTeacherId is string && resource.data.responsibleTeacherId in teacherOwnershipIds()) ||
          (resource.data.assistantIds is list && resource.data.assistantIds.hasAny(teacherOwnershipIds())) ||
          (resource.data.targetType == "class" && resource.data.targetId is string && isTeacherAssignedToClassId(resource.data.targetId)) ||
          (resource.data.classId is string && isTeacherAssignedToClassId(resource.data.classId))
        );
    }

    function isTeacherAssignedToCourseAssignmentId(assignmentId) {
      return (isTeacher() || isAssistant())
        && user() != null
        && assignmentId is string
        && exists(/databases/$(db)/documents/courseAssignments/$(assignmentId))
        && isTeacherAssignedToCourseAssignment(get(/databases/$(db)/documents/courseAssignments/$(assignmentId)).data);
    }

    function isCourseAssignmentOwnershipAdmin() {
      return isSuperAdmin() || isPlatformAdmin() || isSchoolAdmin();
    }

    function courseAssignmentOwnershipKeys() {
      return ["responsibleTeacherId", "assistantIds", "teacherOwnershipIds", "responsibleTeacherName", "assistantNames"];
    }

    function courseAssignmentCreateOwnershipAllowed() {
      return isCourseAssignmentOwnershipAdmin()
        || (
          (!(request.resource.data.responsibleTeacherId is string) || request.resource.data.responsibleTeacherId == "")
          && (!(request.resource.data.assistantIds is list) || request.resource.data.assistantIds.size() == 0)
          && (!(request.resource.data.teacherOwnershipIds is list) || request.resource.data.teacherOwnershipIds.size() == 0)
          && (!(request.resource.data.responsibleTeacherName is string) || request.resource.data.responsibleTeacherName == "")
          && (!(request.resource.data.assistantNames is list) || request.resource.data.assistantNames.size() == 0)
        );
    }

    function courseAssignmentUpdateOwnershipAllowed() {
      return isCourseAssignmentOwnershipAdmin()
        || !request.resource.data.diff(resource.data).affectedKeys().hasAny(courseAssignmentOwnershipKeys());
    }

    function isStudentInTeacherClass() {
      return isTeacher()
        && user() != null
        && (
          (resource.data.classId is string && isTeacherAssignedToClassId(resource.data.classId)) ||
          (resource.data.primaryClassId is string && isTeacherAssignedToClassId(resource.data.primaryClassId)) ||
          (resource.data.classId is string && resource.data.classId in teacherClassIds()) ||
          (resource.data.primaryClassId is string && resource.data.primaryClassId in teacherClassIds()) ||
          (resource.data.className is string && resource.data.className in teacherClassIds()) ||
          (resource.data.classIds is list && resource.data.classIds.hasAny(teacherClassIds())) ||
          (resource.data.assignedClassIds is list && resource.data.assignedClassIds.hasAny(teacherClassIds()))
        );
    }

    function isUserInTeacherClass(uid) {
      return isTeacher()
        && user() != null
        && exists(/databases/$(db)/documents/users/$(uid))
        && (
          (get(/databases/$(db)/documents/users/$(uid)).data.classId is string
            && isTeacherAssignedToClassId(get(/databases/$(db)/documents/users/$(uid)).data.classId)) ||
          (get(/databases/$(db)/documents/users/$(uid)).data.primaryClassId is string
            && isTeacherAssignedToClassId(get(/databases/$(db)/documents/users/$(uid)).data.primaryClassId)) ||
          (get(/databases/$(db)/documents/users/$(uid)).data.classId is string
            && get(/databases/$(db)/documents/users/$(uid)).data.classId in teacherClassIds()) ||
          (get(/databases/$(db)/documents/users/$(uid)).data.primaryClassId is string
            && get(/databases/$(db)/documents/users/$(uid)).data.primaryClassId in teacherClassIds()) ||
          (get(/databases/$(db)/documents/users/$(uid)).data.className is string
            && get(/databases/$(db)/documents/users/$(uid)).data.className in teacherClassIds()) ||
          (get(/databases/$(db)/documents/users/$(uid)).data.classIds is list
            && get(/databases/$(db)/documents/users/$(uid)).data.classIds.hasAny(teacherClassIds())) ||
          (get(/databases/$(db)/documents/users/$(uid)).data.assignedClassIds is list
            && get(/databases/$(db)/documents/users/$(uid)).data.assignedClassIds.hasAny(teacherClassIds()))
        );
    }

    function isTeacherInExternalTaskScope() {
      return request.auth != null
        && (isTeacher() || isAssistant())
        && user() != null
        && (
          (resource.data.teacherOwnershipIds is list && resource.data.teacherOwnershipIds.hasAny(teacherOwnershipIds())) ||
          (resource.data.assignmentId is string && isTeacherAssignedToCourseAssignmentId(resource.data.assignmentId)) ||
          (resource.data.courseAssignmentId is string && isTeacherAssignedToCourseAssignmentId(resource.data.courseAssignmentId)) ||
          (resource.data.classId is string && isTeacherAssignedToClassId(resource.data.classId)) ||
          (resource.data.classId is string && resource.data.classId in teacherClassIds()) ||
          (resource.data.locationId is string && resource.data.locationId in teacherLocationIds())
        );
    }

    // 👤 USERS
    match /users/{uid} {
      allow read, get, list: if
        // 1. Allow the user to read their own profile (essential for claims)
        isSameStudent(uid) ||
        (resource.data.authUid is string && resource.data.authUid == request.auth.uid) ||
        // 2. Allow any Accounting Admin to read ANY user document
        isAccountingAdmin() ||
        // 3. Allow Teachers to read students in their classes (existing logic)
        isStudentInTeacherClass();

      // Allow admins to create new users and allow both admins and user to update profile
      allow create: if isAccountingAdmin() || isSameStudent(uid);
      allow update: if isAccountingAdmin() || isSameStudent(uid) || (resource.data.authUid is string && resource.data.authUid == request.auth.uid);

      allow delete: if isSuperAdmin() || isPlatformAdmin();

      match /modules_completed/{moduleId} {
        allow read: if isSameStudent(uid)
                        || isSuperAdmin()
                        || isPlatformAdmin()
                        || isSchoolAdmin();
        allow write: if isSameStudent(uid);
      }
    }

  // 📍 LOCATIONS
    match /locations/{locId} {
      allow read: if true;
      allow create, delete: if isSuperAdmin() || isPlatformAdmin();
      allow update: if isSuperAdmin()
        || isPlatformAdmin()
        || isSchoolAdmin()
        || isCourseEditor();

      // 🧾 EXPENSE CATEGORIES (subcollection)
      match /expense_categories/{categoryId} {
        allow read, list, create, update, delete: if isAccountingAdmin();
      }

      // 📚 CLASSES (subcollection)
      // --- ADD THIS BLOCK ---
      match /classes/{classId} {
          // Allow accountants/admins to read and write classes
          allow read, list: if isAccountingAdmin()
            || request.auth != null
            || isStudent()
            || (isTeacher() && (classId in teacherClassIds() || locId in teacherLocationIds()))
            || isTeacherAssignedToClass(resource.data, classId);
          allow create, update, delete: if isAccountingAdmin();
      }
    }


    // 📚 CLASSES
    match /classes/{classId} {
      allow read: if true;
      allow write: if isSuperAdmin()
                  || isPlatformAdmin()
                  || (isSchoolAdmin() && sameSchool());
    }

    // 🧠 CLASS TEMPLATES
    match /classTemplates/{templateId} {
      allow read: if isSuperAdmin() || isPlatformAdmin() || isSchoolAdmin();
      allow write: if isSuperAdmin() || isPlatformAdmin() || (isSchoolAdmin() && sameSchool());
    }

    // 📘 COURSES
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();

      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();

        match /sessions/{sessionId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
        }

        match /learningContent/{contentId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
        }

        match /learningModes/{modeId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();

          match /steps/{stepId} {
            allow read: if true;
            allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
          }
        }
      }
    }

    // 🎯 COURSE ASSIGNMENTS
    match /courseAssignments/{assignmentId} {
      allow get, list: if request.auth != null;

      allow create: if request.auth != null && (
        isSuperAdmin() ||
        isPlatformAdmin() ||
        isSchoolAdmin() ||
        isCourseEditor()
      ) && courseAssignmentCreateOwnershipAllowed();

      allow update: if request.auth != null && (
        isSuperAdmin() ||
        isPlatformAdmin() ||
        isSchoolAdmin() ||
        isCourseEditor()
      ) && courseAssignmentUpdateOwnershipAllowed();

      allow delete: if isSuperAdmin() || isPlatformAdmin();
    }

    // 🧾 EXTERNAL TASK SUBMISSIONS
    match /externalTaskSubmissions/{submissionId} {
      allow create: if request.auth != null
        && isStudent()
        && isSameStudent(request.resource.data.studentId)
        && request.resource.data.reviewStatus == "pending"
        && request.resource.data.status == "submitted";

      allow read, list: if request.auth != null && (
        isSameStudent(resource.data.studentId) ||
        isExternalTaskAdminReviewer() ||
        isTeacherInExternalTaskScope()
      );

      allow update: if request.auth != null && (
        (
          isStudent()
          && isSameStudent(resource.data.studentId)
          && (resource.data.reviewStatus == "pending" || resource.data.reviewStatus == "needsWork")
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            "reviewStatus",
            "reviewedBy",
            "reviewedAt",
            "teacherFeedback"
          ])
        ) ||
        (
          (isExternalTaskAdminReviewer() || isTeacherInExternalTaskScope())
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "reviewStatus",
            "reviewedBy",
            "reviewedAt",
            "teacherFeedback",
            "status",
            "updatedAt"
          ])
        )
      );

      allow delete: if isSuperAdmin() || isPlatformAdmin();
    }

    // 📚 CATALOG COURSES (New V2 Core Database)
    match /catalogCourses/{courseId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();

      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();

        match /sessions/{sessionId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
        }

        match /learningContent/{contentId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
        }

        match /learningModes/{modeId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();

          match /steps/{stepId} {
            allow read: if true;
            allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
          }
        }
      }
    }

    // 🎓 STUDENT PROGRESS
    match /studentProgress/{studentId} {
      allow read: if request.auth != null && (
        isSameStudent(studentId) ||
        isUserInTeacherClass(studentId) ||
        isSuperAdmin() ||
        isPlatformAdmin() ||
        isSchoolAdmin()
      );
      allow create, update: if isSameStudent(studentId);
      allow delete: if isSuperAdmin() || isPlatformAdmin();

      match /courses/{courseId} {
        allow read: if request.auth != null && (
          isSameStudent(studentId) ||
          isUserInTeacherClass(studentId) ||
          isSuperAdmin() ||
          isPlatformAdmin() ||
          isSchoolAdmin()
        );
        allow create, update: if isSameStudent(studentId);
        allow delete: if isSuperAdmin() || isPlatformAdmin();

        match /sessions/{sessionId} {
          allow read: if request.auth != null && (
            isSameStudent(studentId) ||
            isUserInTeacherClass(studentId) ||
            isSuperAdmin() ||
            isPlatformAdmin() ||
            isSchoolAdmin()
          );
          allow create, update: if isSameStudent(studentId);
          allow delete: if isSuperAdmin() || isPlatformAdmin();
        }
      }
    }

    // 👥 CUSTOMERS
    match /customers/{customerId} {
      allow read, list: if isAccountingAdmin();
      allow create: if isAccountingAdmin();
      allow update: if isAccountingAdmin();
      allow delete: if isSuperAdmin() || isPlatformAdmin();
    }

    // 🧩 STEP DEFINITIONS (RUNTIME STEPS)
    match /courses/{courseId}/modules/{moduleId}/steps/{stepId} {
      allow read: if true; // students must read steps to run engines
      allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
    }

    // 🧩 STEP DEFINITIONS FOR CATALOG COURSES (RUNTIME STEPS)
    match /catalogCourses/{courseId}/modules/{moduleId}/steps/{stepId} {
      allow read: if true; // students must read steps to run engines
      allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
    }


    // 📊 STEP RESULTS (Used by Teacher Dashboard)
    match /stepResults/{resultId} {
      allow read: if request.auth != null && (
          isTeacher() || isSuperAdmin() || isPlatformAdmin() || isSchoolAdmin()
      );

      // Optional: allow students to write their own results
      allow create: if isSameStudent(request.resource.data.studentId);

      // Optional: only admins can delete
      allow delete: if isSuperAdmin() || isPlatformAdmin();

      // Prevent anyone from updating results (they should be immutable)
      allow update: if false;
    }


    // 🔐 PERMISSIONS
    match /permissions/{permId} {
      allow read, write: if isSuperAdmin() || isPlatformAdmin();
    }

    // ⚙️ SETTINGS
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAccountingAdmin();
    }
    match /fees/{docId} {
      allow read: if request.auth != null;
      allow write: if isAccountingAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isPlatformAdmin();
    }

    // ---
    // --- ACCOUNTING COLLECTIONS ---
    // ---

    // 💰 PAYMENTS
    match /payments/{payId} {
      // Use the accounting helper
      allow read, write: if isAccountingAdmin();
    }

    // 💸 EXPENSES
    match /expenses/{expenseId} {
      // Use the accounting helper
      allow read, write: if isAccountingAdmin();
    }

    // 📄 SUBSCRIPTIONS
    match /subscriptions/{subId} {
      allow read, write: if isSuperAdmin() || isAccountant();
    }

    // 🏷 STEP METADATA (Tags)
    match /step_metadata/{stepId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
    }

    // 🛒 STORE PURCHASES
    match /store_purchases/{purchaseId} {
      allow read: if isSuperAdmin() || isAccountant() || isSchoolAdmin();
      allow write: if isSuperAdmin() || isAccountant();
    }

    // 📊 AUDIT LOGS
    match /audit_logs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // 🧾 RECURRING BILLS
    match /recurring_bills/{billId} {
      // Use the accounting helper
      allow read, list, create, update, delete: if isAccountingAdmin();

      match /history/{entryId} {
        allow read, write: if isAccountingAdmin();
      }
    }

    // 💵 SALARIES
    match /salaries/{salaryId} {
      // Use the same accounting helper
      allow read, list, create, update, delete: if isAccountingAdmin();
    }

    // 📋 LESSON LOG
    match /lesson_log/{lessonId} {
      // Allow accountants/admins to read and write lesson logs
      allow read, write: if isAccountingAdmin();
    }

    // 🧩 STEP COLLECTION GROUP (for editors, registry, runtime)
    match /{path=**}/steps/{stepId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
    }

    match /stepTypes/{stepTypeId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
    }

    // 🧩 SYSTEM STEP TYPES (Cloud Code)
    match /system_step_types/{stepId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isPlatformAdmin() || isCourseEditor();
    }
  }
}
